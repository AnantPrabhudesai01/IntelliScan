<style>
    body { font-family: Arial, sans-serif; line-height: 1.8; color: #ffffff; background-color: #1a1a1a; padding: 40px; }
    /* The image shows a dark background but the document itself should be white for printing usually. 
       However, I will use a clean professional look that matches the spacing of the image. */
    .content { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #333; background-color: #fff; padding: 40px; border-radius: 8px; }
    h1 { font-size: 18pt; font-weight: bold; margin-bottom: 30px; color: #000; }
    .ref-item { font-size: 11pt; margin-bottom: 12px; }
    a { color: #007bff; text-decoration: underline; }
</style>
</head>
