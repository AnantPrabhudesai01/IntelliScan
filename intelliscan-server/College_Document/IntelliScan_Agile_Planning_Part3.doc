<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'>
<head>
    <meta charset="utf-8">
    <title>Burnt Chart Part 3</title>
    <!--[if gte mso 9]>
    <xml>
        <w:WordDocument>
            <w:View>Print</w:View>
            <w:Zoom>100</w:Zoom>
            <w:DoNotOptimizeForBrowser/>
        </w:WordDocument>
    </xml>
    <![endif]-->
    <style>
        body { font-family: "Times New Roman", serif; font-size: 12pt; text-align: center; }
        .chart-container { border: 1pt solid #ccc; padding: 10pt; display: inline-block; }
    </style>
</head>
<body>
    <br>
    <div class="chart-container">
        <!-- The image is perfectly generated and placed alongside this folder, MS Word will auto-load it! -->
        <img src="Burnt_Chart.png" width="800" height="500" alt="Burnt Chart">
    </div>
</body>
</html>
