PORT=5000
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=30d
SEED_DEMO_USERS=true

# Gemini OCR + AI features
GEMINI_API_KEY=your_google_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional Tesseract fallback language (requires traineddata availability)
# Example: eng, eng+osd, eng+hin
TESSERACT_LANG=eng

# Fallback behavior when Gemini is unavailable:
# true  -> return deterministic fallback responses instead of failing hard
# false -> return error responses for missing/down AI provider
ALLOW_MOCK_AI_FALLBACK=true

# Razorpay (Billing & Plans)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Real email campaign delivery (leave blank to run in simulated mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=
