# === SERVER ===
PORT=5000
NODE_ENV=development
SERVER_URL=http://localhost:5000
APP_PUBLIC_URL=http://localhost:5173

# === SECURITY ===
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION
JWT_EXPIRES_IN=30d
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === AI / OCR ===
GEMINI_API_KEY=your_google_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=your_openai_api_key_optional
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_API_KEY=your_openrouter_api_key_optional
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
HUGGINGFACE_API_KEY=your_huggingface_api_key_optional

# Optional Tesseract fallback language (requires traineddata availability)
# Example: eng, eng+osd, eng+hin
TESSERACT_LANG=eng

# === PAYMENTS ===
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# === EMAIL / SMTP ===
# Required for real email sending (AI Drafts, Campaigns, Invites).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=IntelliScan <noreply@intelliscan.io>

# Contact Us form destination (public website)
CONTACT_US_TO=contact@intelliscan.io
CONTACT_US_FROM=IntelliScan Website <noreply@intelliscan.io>

# === OIDC / SSO (Optional) ===
# These power Google / Okta / Azure AD sign-in buttons on the login page.
# If not set, the SSO button will show "Not configured" in UI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OKTA_ISSUER=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# === STORAGE ===
# Replace AWS S3 with ImgBB API Key for completely free image hosting.
IMGBB_API_KEY=

# === DATABASE ===
# PostgreSQL/Supabase URL required.
DATABASE_URL=postgres://[user].[project]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# === APP ===
SEED_DEMO_USERS=false
