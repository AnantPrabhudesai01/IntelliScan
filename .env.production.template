# ══════════════════════════════════════════════════════════════════
# IntelliScan — Production Environment Template (Vercel)
# ══════════════════════════════════════════════════════════════════
# Instructions: Copy these keys into your Vercel Project Settings > Environment Variables.

# --- Database (Supabase) ---
# Format: postgres://postgres.[USER]:[PASS]@[HOST]:5432/postgres
DATABASE_URL=
POSTGRES_URL=

# --- Authentication ---
JWT_SECRET=
# Google SSO (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://[your-domain].vercel.app/api/auth/google/callback

# --- AI Engines ---
# Primary (Gemini)
GOOGLE_GEMINI_API_KEY=
# Fallbacks (OpenRouter/OpenAI) 
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# --- Messaging & Media ---
# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ENABLE_WHATSAPP=true
# Image Hosting (Imgbb)
IMGBB_API_KEY=

# --- Billing (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- SMTP (Email sequences) ---
# Example for Gmail: smtp.gmail.com, 465, your-email, app-password
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- System ---
APP_DOMAIN=[your-domain].vercel.app
CLIENT_ORIGIN=https://[your-domain].vercel.app
CRON_SECRET=[generate-a-long-random-string]
NODE_ENV=production
