{
  "name": "intelliscan-monorepo",
  "private": true,
  "workspaces": [
    "intelliscan-app",
    "intelliscan-server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=intelliscan-app\" \"npm run dev --workspace=intelliscan-server\"",
    "build": "npm run build --workspace=intelliscan-app && mkdir -p dist && cp -r intelliscan-app/dist/* dist/",
    "start": "npm start --workspace=intelliscan-server",
    "install-all": "npm install && npm install --workspace=intelliscan-app && npm install --workspace=intelliscan-server"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "@vercel/analytics": "^2.0.1",
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "marked": "^17.0.5",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "openai": "^6.33.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "plantuml-encoder": "^1.4.0",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3",
    "tesseract.js": "^7.0.0",
    "twilio": "^5.13.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  }
}
