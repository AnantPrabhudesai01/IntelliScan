{
  "version": 2,
  "name": "intelliscan",
  "functions": {
    "intelliscan-server/api/index.js": {
      "runtime": "nodejs24.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/intelliscan-server/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/intelliscan-app/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/intelliscan-app/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/process-all",
      "schedule": "0 0 * * *"
    }
  ]
}
