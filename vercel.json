{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "intelliscan-server/**",
      "maxDuration": 20
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
