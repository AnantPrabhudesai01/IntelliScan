{
  "version": 2,
  "name": "intelliscan",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "functions/api-gateway.js": {
      "runtime": "nodejs24.x",
      "memory": 1024,
      "maxDuration": 10,
      "includeFiles": "intelliscan-server/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/functions/api-gateway.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/process-all",
      "schedule": "0 0 * * *"
    }
  ]
}
