{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "intelliscan-app/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "intelliscan-server/**",
      "maxDuration": 60
    }
  }
}